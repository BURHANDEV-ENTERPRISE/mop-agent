# MOP-AGENT web — copy to .env and fill in.
PORT=3000
MOP_AGENT_DEPLOY_MODE=public   # public | local

# --- Fasa 2 (auth + db + secrets) ---
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3000
# MOP_AGENT_SECRET=          # AES-GCM key for provider keys at rest (32 bytes hex)
# MOP_AGENT_DATA_DIR=        # defaults to OS data dir if unset
# MOP_AGENT_MODEL_CACHE=     # local MiniLM model cache; installer puts it under data/models

# --- providers (Fasa 2/3) ---
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# MOP_AGENT_PROVIDER=anthropic   # anthropic | openrouter | echo (default: auto/echo)
# MOP_AGENT_MODEL=

# --- channels (Fasa 4.5) — set a token to auto-start that bot ---
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=

# --- public reachability (so FLOW can dial in directly) ---
# This agent must be reachable from the project machines. Behind nginx + TLS the
# Brain UI uses the browser origin to print the link command, so usually nothing
# to set here. Override only if you serve under a different external URL:
# MOP_AGENT_PUBLIC_URL=https://brain.example.com
